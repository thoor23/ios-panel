# Copy to .env and change for your environment.
# For production on thorodin.in use .env.production (or set these).
#
# Backend API base URL (no trailing slash). Required in production.
# Production: https://api.thorodin.in
VITE_API_BASE_URL=http://localhost:8550

# Local storage key for auth token.
VITE_AUTH_TOKEN_KEY=nextios_auth_token

# License app name (e.g. for key generation).
VITE_LICENSE_APP=Next

# Dev server port (optional).
VITE_DEV_PORT=8080
