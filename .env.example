# Backend API base URL (no trailing slash).
# Production (thorodin.in): https://api.thorodin.in
# Local: http://localhost:8550
VITE_API_BASE_URL=http://localhost:8550

# Local storage key for auth token.
VITE_AUTH_TOKEN_KEY=nextios_auth_token

# License app name (e.g. for key generation).
VITE_LICENSE_APP=Next

# Dev server port (optional; used by vite.config.ts).
VITE_DEV_PORT=8080
